rules_version = '2';

// ─────────────────────────────────────────────────────────────────────────────
// Firestore Security Rules — Lyvoo
//
// Para publicar: Firebase Console → Firestore Database → Regras → colar → Publicar
// (ou via CLI: firebase deploy --only firestore:rules)
//
// O acesso de administrador baseia-se EXCLUSIVAMENTE no custom claim
// { admin: true } no token (definido com set-admin-claims.js). Não há fallback
// por email — para promover alguém a admin, corre set-admin-claims.js.
// ─────────────────────────────────────────────────────────────────────────────

service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null && request.auth.token.admin == true;
    }

    function isOwner(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    // Campos controlados pelo servidor/admin — o cliente NUNCA os pode alterar.
    // estado/plano/pagamento são definidos pelo webhook Stripe (Admin SDK, que
    // ignora estas regras) e pelo admin (via isAdmin). Sem isto, um cliente
    // autenticado podia fazer updateDoc({estado:4}) no seu próprio doc e saltar
    // o pagamento / desbloquear a área de resultados. (Fix 1 — OWASP A01)
    // `prioridades` (DA-05, roadmap) é conteúdo clínico gerado pelo admin/motor
    // de regras — bloqueado aqui pela mesma razão que estado/plano: sem isto,
    // um cliente podia fabricar as suas próprias "prioridades" via updateDoc.
    //
    // `resultados`/`planoAlimentar`/`suplementacao`/`relatorio` (DA-22) faltavam
    // aqui — só o admin os deve escrever (biomarcadores, plano nutricional,
    // suplementação, relatório médico). Sem isto, um cliente autenticado podia
    // fazer updateDoc({resultados:{...}}) e fabricar os seus próprios resultados
    // de análises, plano alimentar, suplementação ou relatório médico.
    // Confirmado (2026-07-01): nenhum fluxo em dashboard.html escreve nestes
    // campos como owner — só lê. O único setDoc do cliente (perfil, com
    // merge:true) não os toca.
    function ownerKeepsLockedFields() {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny([
        'estado','estadoLabel','plano','planoNome','planoValidoAte',
        'stripeSessionId','cicloAtual','clienteId','seq','arquivado','prioridades',
        'resultados','planoAlimentar','suplementacao','relatorio'
      ]);
    }

    // Validação dos campos de perfil editáveis pelo cliente: cada um, quando
    // presente no doc resultante, tem de ser string e dentro de um tamanho
    // razoável. Defesa em profundidade sobre o field-lock — impede tipos errados
    // ou blobs gigantes nos campos livres. O admin não está sujeito a isto. (D4)
    function validProfileFields(d) {
      return (!('firstName' in d)    || (d.firstName is string    && d.firstName.size()    <= 100))
        && (!('lastName' in d)       || (d.lastName is string     && d.lastName.size()     <= 100))
        && (!('phone' in d)          || (d.phone is string        && d.phone.size()        <= 40))
        && (!('dob' in d)            || (d.dob is string          && d.dob.size()          <= 20))
        && (!('genero' in d)         || (d.genero is string       && d.genero.size()       <= 40))
        && (!('morada' in d)         || (d.morada is string       && d.morada.size()       <= 250))
        && (!('distrito' in d)       || (d.distrito is string     && d.distrito.size()     <= 80))
        && (!('concelho' in d)       || (d.concelho is string     && d.concelho.size()     <= 80))
        && (!('codigoPostal' in d)   || (d.codigoPostal is string && d.codigoPostal.size() <= 20))
        && (!('email' in d)          || (d.email is string        && d.email.size()        <= 254));
    }

    // ── Perfis de cliente (registar/dashboard) + gestão clínica (admin) ──
    match /users/{uid} {
      // Registo: só o próprio, e o doc só pode nascer em estado 1 (sem pagamento).
      allow create: if isAdmin() || (
        isOwner(uid)
        && request.resource.data.estado == 1
        && !request.resource.data.keys().hasAny(['stripeSessionId','planoValidoAte','cicloAtual','clienteId','seq'])
        && validProfileFields(request.resource.data)
      );
      // Update: o admin pode tudo; o dono só se NÃO mexer nos campos bloqueados
      // (pode editar perfil, responder a convites de consulta, marcar notificações
      //  como vistas, pedir eliminação RGPD — nada disso toca nos campos acima).
      allow update: if isAdmin() || (isOwner(uid) && ownerKeepsLockedFields() && validProfileFields(request.resource.data));
      allow read:   if isOwner(uid) || isAdmin();
      allow delete: if isAdmin();

      // Histórico de análises: escrito pelo admin, lido pelo cliente
      match /analises/{analiseId} {
        allow read:  if isOwner(uid) || isAdmin();
        allow write: if isAdmin();
      }
    }

    // ── Chat cliente ↔ equipa Lyvoo ──
    // O admin precisa de listar todos os chats (indicadores de não lidas);
    // cada cliente só acede ao seu próprio.
    match /chats/{uid} {
      allow read, write: if isOwner(uid) || isAdmin();

      match /mensagens/{msgId} {
        allow read, create: if isOwner(uid) || isAdmin();
        allow update, delete: if isAdmin();
      }
    }

    // ── Marcações de consultas de nutrição ──
    // Contêm PII (nome, email, link de videochamada), por isso a LEITURA é
    // restrita ao dono e ao admin (Fix 3). A disponibilidade do calendário é
    // servida por `busySlots` (sem PII), mantido pela Cloud Function
    // syncBusySlots — é esse que o cliente lê em bkLoadBusy.
    match /agendamentosNutri/{agId} {
      allow read: if isAdmin() ||
        (request.auth != null && resource.data.uid == request.auth.uid);
      allow create: if isAdmin() ||
        (request.auth != null && request.resource.data.uid == request.auth.uid);
      allow update: if isAdmin() ||
        (request.auth != null && resource.data.uid == request.auth.uid
         && request.resource.data.uid == request.auth.uid);
      allow delete: if isAdmin() ||
        (request.auth != null && resource.data.uid == request.auth.uid);
    }

    // ── Disponibilidade do calendário (sem PII) ──
    // Espelho só-leitura de horas ocupadas por dia, mantido pela Cloud Function
    // syncBusySlots (Admin SDK). Qualquer autenticado lê; ninguém escreve a
    // partir do cliente.
    match /busySlots/{data} {
      allow read:  if request.auth != null;
      allow write: if false;
    }

    // ── Contadores internos (sequência de clienteId, etc.) ──
    // Mantidos só pelo Admin SDK (Cloud Function assignClienteId). O cliente
    // nunca lê nem escreve; o admin pode ler para diagnóstico.
    match /counters/{counterId} {
      allow read:  if isAdmin();
      allow write: if false;
    }

    // ── Erros do webhook Stripe (observabilidade) ──
    // Escritos só pelo Admin SDK (Cloud Function stripeWebhook). Lidos só pelo
    // admin (para reconciliar pagamentos que falharam o processamento). (B3)
    match /webhookErrors/{errId} {
      allow read:  if isAdmin();
      allow write: if false;
    }

    // ── Registo de auditoria de eliminações RGPD (sem PII) ──
    // Escrito só pelo Admin SDK (Cloud Function eliminarUtilizadorRGPD). Lido só
    // pelo admin. Prova de conformidade com o direito ao apagamento. (D5)
    match /eliminacoesRGPD/{uid} {
      allow read:  if isAdmin();
      allow write: if false;
    }

    // ── Lista de espera (formulário público em contacto.html) ──
    // Submetida por visitantes (sem auth) via setDoc com id derivado do email,
    // por isso create+update têm de continuar abertos — MAS validados: forma de
    // email, nº de campos limitado e mensagem com teto (anti-spam/anti-custo).
    // Removido o antigo `update: if true` (permitia reescrever qualquer entrada).
    // Proteção real contra bots = re-ativar App Check. (Fix 2)
    match /waitlist/{entryId} {
      function validWaitlist() {
        return request.resource.data.email is string
          && request.resource.data.email.size() > 3
          && request.resource.data.email.size() < 200
          && request.resource.data.keys().hasAll(['email','criadoEm'])
          && request.resource.data.size() <= 10
          && (!('mensagem' in request.resource.data)
              || request.resource.data.mensagem.size() < 2000);
      }
      allow create, update: if validWaitlist();
      allow read, delete: if isAdmin();
    }
  }
}
