rules_version = '2';

// ─────────────────────────────────────────────────────────────────────────────
// Firestore Security Rules — Lyvoo
//
// Para publicar: Firebase Console → Firestore Database → Regras → colar → Publicar
// (ou via CLI: firebase deploy --only firestore:rules)
//
// O acesso de administrador baseia-se no custom claim { admin: true } no token
// (definido com set-admin-claims.js), com fallback para os emails da equipa —
// os mesmos de ADMIN_EMAILS em admin.html e login.html.
// ─────────────────────────────────────────────────────────────────────────────

service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null && (
        request.auth.token.admin == true ||
        request.auth.token.email in ['ricardo.lyvoo@gmail.com', 'hello@lyvoo.pt']
      );
    }

    function isOwner(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    // ── Perfis de cliente (registar/dashboard) + gestão clínica (admin) ──
    match /users/{uid} {
      allow create: if isOwner(uid);
      allow read, update: if isOwner(uid) || isAdmin();
      allow delete: if isAdmin();

      // Histórico de análises: escrito pelo admin, lido pelo cliente
      match /analises/{analiseId} {
        allow read: if isOwner(uid) || isAdmin();
        allow write: if isAdmin();
      }
    }

    // ── Chat cliente ↔ equipa Lyvoo ──
    // O admin precisa de listar todos os chats (indicadores de não lidas);
    // cada cliente só acede ao seu próprio.
    match /chats/{uid} {
      allow read, write: if isOwner(uid) || isAdmin();

      match /mensagens/{msgId} {
        allow read, create: if isOwner(uid) || isAdmin();
        allow update, delete: if isAdmin();
      }
    }

    // ── Marcações de consultas de nutrição ──
    // Leitura por qualquer autenticado: o calendário de agendamento precisa de
    // ver os horários ocupados de todos os clientes (bkLoadBusy na dashboard).
    match /agendamentosNutri/{agId} {
      allow read: if request.auth != null;
      allow create: if isAdmin() ||
        (request.auth != null && request.resource.data.uid == request.auth.uid);
      allow update, delete: if isAdmin() ||
        (request.auth != null && resource.data.uid == request.auth.uid);
    }

    // ── Lista de espera (formulário público em contacto.html) ──
    // create/update sem auth: o formulário do site é submetido por visitantes.
    match /waitlist/{entryId} {
      allow create, update: if true;
      allow read, delete: if isAdmin();
    }
  }
}
